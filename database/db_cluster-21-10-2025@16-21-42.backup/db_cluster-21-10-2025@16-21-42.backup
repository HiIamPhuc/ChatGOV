COPY public.sessions (id, session_id, user_id, chat_history, title, created_at, updated_at, deleted) FROM stdin;
a07879e1-bf5a-4e52-a656-96c0f4a59b7a	ff5d3bd9-46c6-4420-8e40-6c46c321ceba	f5eca8ab-6651-4282-b86f-3654b802bf8c	[{"data": {"id": "db0fd790-643d-4904-b293-51d99fe9b66b", "name": null, "type": "human", "content": "tôi muốn đăng ký tạm trú chi tiết", "example": false, "additional_kwargs": {}, "response_metadata": {}}, "type": "human"}, {"data": {"id": "run--57ab43b5-9bb5-4aa2-b73b-51c64cd7fa73-0", "name": null, "type": "ai", "content": "", "example": false, "tool_calls": [{"id": "a321a46f-31e9-4d9a-87b4-d923776df7a2", "args": {"user_request": "đăng ký tạm trú"}, "name": "find_available_services", "type": "tool_call"}], "usage_metadata": {"input_tokens": 1424, "total_tokens": 1549, "output_tokens": 125, "input_token_details": {"cache_read": 0}, "output_token_details": {"reasoning": 102}}, "additional_kwargs": {"function_call": {"name": "find_available_services", "arguments": "{\\"user_request\\": \\"\\\\u0111\\\\u0103ng k\\\\u00fd t\\\\u1ea1m tr\\\\u00fa\\"}"}}, "response_metadata": {"model_name": "gemini-2.5-flash", "finish_reason": "STOP", "safety_ratings": [], "prompt_feedback": {"block_reason": 0, "safety_ratings": []}}, "invalid_tool_calls": []}, "type": "ai"}, {"data": {"id": "bca139a6-1033-4146-b84a-ff4e54c6cac7", "name": "find_available_services", "type": "tool", "status": "success", "content": "**CÁC DỊCH VỤ CÔNG CÓ SẴN:**\\n\\n1. **Đăng ký tạm trú**\\n   • ID: `26356`\\n   • Mã thủ tục: `1.004194`\\n   • URL: `https://dichvucong.bocongan.gov.vn/bocongan/bothutuc/tthc?matt=26356`\\n\\n2. **Khai báo thông tin về cư trú đối với người chưa đủ điều kiện đăng ký thường trú, đăng ký tạm trú**\\n   • ID: `26492`\\n   • Mã thủ tục: `1.01004`\\n   • URL: `https://dichvucong.bocongan.gov.vn/bocongan/bothutuc/tthc?matt=26492`\\n\\n3. **Xóa đăng ký tạm trú**\\n   • ID: `26552`\\n   • Mã thủ tục: `1.010028`\\n   • URL: `https://dichvucong.bocongan.gov.vn/bocongan/bothutuc/tthc?matt=26552`\\n\\n4. **Đăng ký thường trú**\\n   • ID: `26360`\\n   • Mã thủ tục: `1.004222`\\n   • URL: `https://dichvucong.bocongan.gov.vn/bocongan/bothutuc/tthc?matt=26360`\\n\\n5. **Xóa đăng ký thường trú**\\n   • ID: `26348`\\n   • Mã thủ tục: `1.003197`\\n   • URL: `https://dichvucong.bocongan.gov.vn/bocongan/bothutuc/tthc?matt=26348`\\n\\n\\n*Tìm thấy 5 dịch vụ phù hợp. Để biết chi tiết về bất kỳ thủ tục nào, bạn hãy nói: 'Cho tôi biết về thủ tục [ID]' hoặc 'Thông tin [loại thông tin] của thủ tục [ID]'*", "artifact": null, "tool_call_id": "a321a46f-31e9-4d9a-87b4-d923776df7a2", "additional_kwargs": {}, "response_metadata": {}}, "type": "tool"}, {"data": {"id": "run--b68e7100-5083-43d7-99af-62d6752c28e3-0", "name": null, "type": "ai", "content": "Chào bạn Tin,\\n\\nBạn muốn đăng ký tạm trú, tôi đã tìm thấy thông tin về dịch vụ này trên Cổng Dịch vụ công Bộ Công an.\\n\\n**Tên dịch vụ:** Đăng ký tạm trú\\n**URL:** [https://dichvucong.bocongan.gov.vn/bocongan/bothutuc/tthc?matt=26356](https://dichvucong.bocongan.gov.vn/bocongan/bothutuc/tthc?matt=26356)\\n\\nĐể biết chi tiết về trình tự thực hiện, hồ sơ cần chuẩn bị, thời hạn giải quyết và các thông tin liên quan khác, bạn vui lòng truy cập vào đường dẫn trên. Trang này sẽ cung cấp đầy đủ hướng dẫn để bạn có thể thực hiện thủ tục đăng ký tạm trú một cách thuận lợi nhất.\\n\\nNếu có bất kỳ câu hỏi nào khác về dịch vụ này hoặc các thủ tục hành chính khác, đừng ngần ngại hỏi tôi nhé!", "example": false, "tool_calls": [], "usage_metadata": {"input_tokens": 1334, "total_tokens": 2084, "output_tokens": 750, "input_token_details": {"cache_read": 0}, "output_token_details": {"reasoning": 535}}, "additional_kwargs": {}, "response_metadata": {"model_name": "gemini-2.5-flash", "finish_reason": "STOP", "safety_ratings": [], "prompt_feedback": {"block_reason": 0, "safety_ratings": []}}, "invalid_tool_calls": []}, "type": "ai"}, {"data": {"id": "9ee1d78f-4b84-48cb-9606-6f1a968446a8", "name": null, "type": "human", "content": "tôi muốn đăng ký tạm trú chi tiết", "example": false, "additional_kwargs": {}, "response_metadata": {}}, "type": "human"}, {"data": {"id": "run--9ea07f9e-f4aa-429d-9e8b-c457fa8ec934-0", "name": null, "type": "ai", "content": "", "example": false, "tool_calls": [{"id": "4f4f74e6-5402-407c-9733-f1947ba7cf0a", "args": {"service_id": "26356", "column_name": "all"}, "name": "get_procedure_information", "type": "tool_call"}], "usage_metadata": {"input_tokens": 7601, "total_tokens": 7631, "output_tokens": 30, "input_token_details": {"cache_read": 0}}, "additional_kwargs": {"function_call": {"name": "get_procedure_information", "arguments": "{\\"column_name\\": \\"all\\", \\"service_id\\": \\"26356\\"}"}}, "response_metadata": {"model_name": "gemini-2.5-flash", "finish_reason": "STOP", "safety_ratings": [], "prompt_feedback": {"block_reason": 0, "safety_ratings": []}}, "invalid_tool_calls": []}, "type": "ai"}, {"data": {"id": "371f0581-4e41-4bb8-8754-7a78a93173d6", "name": "get_procedure_information", "type": "tool", "status": "success", "content": "# Đăng ký tạm trú\\n\\n**Mã thủ tục:** 1.004194\\n\\n**Lĩnh vực**:\\nĐăng ký, quản lý cư trú\\n\\n**Cơ quan thực hiện**:\\nCông an Xã\\n\\n**Mức độ dịch vụ trực tuyến**:\\nDịch vụ công trực tuyến một phần\\n\\n**Cách thức thực hiện**:\\n• Trực tiếp\\n\\n• Trực tuyến\\n\\n**Trình tự thực hiện**:\\n\\n• - Bước 1: Cá nhân, tổ chức chuẩn bị hồ sơ theo quy định của pháp luật.- Bước 2: Cá nhân, tổ chức nộp hồ sơ tại Công an cấp xã.- Bước 3: Khi tiếp nhận hồ sơ đăng ký tạm trú, cơ quan đăng ký cư trú kiểm tra tính pháp lý và nội dung hồ sơ:+ Trường hợp hồ sơ đã đầy đủ, hợp lệ thì tiếp nhận hồ sơ và cấp Phiếu tiếp nhận hồ sơ và hẹn trả kết quả (mẫu CT04 ban hành kèm theo Thông tư số 56/2021/TT-BCA) cho người đăng ký;+ Trường hợp hồ sơ đủ điều kiện nhưng chưa đủ hồ sơ thì hướng dẫn bổ sung, hoàn thiện và cấp Phiếu hướng dẫn bổ sung, hoàn thiện hồ sơ (mẫu CT05 ban hành kèm theo Thông tư số 56/2021/TT-BCA) cho người đăng ký;+ Trường hợp hồ sơ không đủ điều kiện thì từ chối và cấp Phiếu từ chối tiếp nhận, giải quyết hồ sơ (mẫu CT06 ban hành kèm theo Thông tư số 56/2021/TT-BCA) cho người đăng ký.- Bước 4: Cá nhân, tổ chức nộp lệ phí đăng ký cư trú theo quy định.- Bước 5: Căn cứ theo ngày hẹn trên Phiếu tiếp nhận hồ sơ và hẹn trả kết quả để nhận thông báo kết quả giải quyết thủ tục đăng ký cư trú (nếu có).\\n\\n⏱**Thời hạn giải quyết**:\\n• Trực tiếp\\n\\n• 03 Ngày làm việc- Nộp hồ sơ trực tiếp tại Công an cấp xã.Thời gian tiếp nhận hồ sơ: Giờ hành chính các ngày làm việc từ thứ 2 đến thứ 6 và sáng thứ 7 hàng tuần (trừ các ngày nghỉ lễ, tết theo quy định của pháp luật).Trực tuyến\\n\\n• 03 Ngày làm việc- Nộp hồ sơ trực tuyến qua các cổng cung cấp dịch vụ công trực tuyến như: Trực tuyến tại Cổng dịch vụ công qua Cổng dịch vụ công quốc gia, hoặc qua Cổng dịch vụ công Bộ Công an, Cổng dịch vụ công quản lý cư trú;Thời gian tiếp nhận hồ sơ: Giờ hành chính các ngày làm việc từ thứ 2 đến thứ 6 và sáng thứ 7 hàng tuần (trừ các ngày nghỉ lễ, tết theo quy định của pháp luật).\\n\\n**Phí**:\\n1\\n\\n**Lệ phí**:\\nKhông\\n\\n**Thành phần hồ sơ**:\\n\\n* Hồ sơ đăng ký tạm trú gồm::\\n\\n* Hồ sơ đăng ký tạm trú gồm::\\n\\nTên giấy tờ: - Tờ khai thay đổi thông tin cư trú (Mẫu CT01 ban hành kèm theo Thông tư số 56/2021/TT-BCA); đối với người đăng ký tạm trú là người chưa thành niên thì trong tờ khai phải ghi rõ ý kiến đồng ý của cha, mẹ hoặc người giám hộ, trừ trường hợp đã có ý kiến đồng ý bằng văn bản; | Mẫu đơn, tờ khai: CT01 Tờ khai thay đổi thông tin cư trú.doc | Số lượng: Bản chính: 1 , Bản sao: 0\\n\\nTên giấy tờ: - Giấy tờ, tài liệu chứng minh chỗ ở hợp pháp. | Số lượng: Bản chính: 1 , Bản sao: 0\\n\\n* Đăng ký tạm trú tại nơi đơn vị đóng quân trong Công an nhân dân, hồ sơ gồm::\\n\\n* Đăng ký tạm trú tại nơi đơn vị đóng quân trong Công an nhân dân, hồ sơ gồm::\\n\\nTên giấy tờ: - Tờ khai thay đổi thông tin cư trú (Mẫu CT01 ban hành kèm theo Thông tư số 56/2021/TT-BCA); | Mẫu đơn, tờ khai: CT01 Tờ khai thay đổi thông tin cư trú.doc | Số lượng: Bản chính: 1 , Bản sao: 0\\n\\nTên giấy tờ: - Giấy giới thiệu của Thủ trưởng đơn vị quản lý trực tiếp ghi rõ nội dung để làm thủ tục đăng ký tạm trú và đơn vị có chỗ ở cho cán bộ chiến sĩ (ký tên, đóng dấu). | Số lượng: Bản chính: 1 , Bản sao: 0\\n\\n* Đăng ký tạm trú theo danh sách, hồ sơ gồm::\\n\\n* Đăng ký tạm trú theo danh sách, hồ sơ gồm::\\n\\nTên giấy tờ: - Tờ khai thay đổi thông tin cư trú (của từng người) (Mẫu CT01 ban hành kèm theo Thông tư số 56/2021/TT-BCA); | Mẫu đơn, tờ khai: CT01 Tờ khai thay đổi thông tin cư trú.doc | Số lượng: Bản chính: 1 , Bản sao: 0\\n\\nTên giấy tờ: - Văn bản đề nghị đăng ký tạm trú trong đó ghi rõ thông tin về chỗ ở hợp pháp kèm danh sách người tạm trú. Danh sách bao gồm những thông tin cơ bản của từng người: họ, chữ đệm và tên; ngày, tháng, năm sinh; giới tính; số định danh cá nhân và thời hạn tạm trú. | Số lượng: Bản chính: 1 , Bản sao: 0\\n\\n**Yêu cầu - điều kiện**:\\nKhông\\n\\n**Căn cứ pháp lý**:\\n• Luật 68/2020/QH14Số: 68/2020/QH14\\n\\n• Thông tư 55/2021/TT-BCASố: 55/2021/TT-BCA\\n\\n• Thông tư 56/2021/TT-BCASố: 56/2021/TT-BCA\\n\\n• Thông tư 57/2021/TT-BCASố: 57/2021/TT-BCA\\n\\n• Thông tư 85/2019/TT-BTCSố: 85/2019/TT-BTC\\n\\n**Biểu mẫu**:\\nFile mẫu:\\n\\n• Tờ khai thay đổi thông tin cư trú (Mẫu CT01 ban hành kèm theo Thông tư số 56/2021/TT-BCA)Tải về\\n\\n• Tờ khai thay đổi thông tin cư trú (Mẫu CT01 ban hành kèm theo Thông tư số 56/2021/TT-BCA); đối với người đăng ký tạm trú là người chưa thành niên thì trong tờ khai phải ghi rõ ý kiến đồng ý của cha, mẹ hoặc người giám hộ, trừ trường hợp đã có ý kiến đồng ý bằng văn bản;Tải về\\n\\n**Kết quả thực hiện**:\\n• Cập nhật thông tin trong Cơ sở dữ liệu quốc gia về dân cư\\n\\n• Cập nhật thông tin trong Cơ sở dữ liệu về cư trú\\n\\n• Thông báo về kết quả giải quyết, hủy bỏ đăng ký cư trú\\n\\n• Phiếu từ chối tiếp nhận, giải quyết hồ sơ\\n\\n**Tài liệu tải xuống**:\\n• https://dichvucong.bocongan.gov.vn/public_dir/tttl/01/giayto/2023_10/1698204115_CT01.doc\\n• https://dichvucong.bocongan.gov.vn/public_dir/tttl/01/giayto/2022_01/1643318294_CT01_To_khai_thay_doi_thong_tin_cu_tru.doc\\n\\n**Link chi tiết**:\\nhttps://dichvucong.bocongan.gov.vn/bocongan/bothutuc/tthc?matt=26356\\n\\n---\\n**Gợi ý:** Bạn có thể hỏi về từng phần cụ thể bằng cách nói: 'Thành phần hồ sơ của thủ tục này' hoặc 'Phí của thủ tục này'", "artifact": null, "tool_call_id": "4f4f74e6-5402-407c-9733-f1947ba7cf0a", "additional_kwargs": {}, "response_metadata": {}}, "type": "tool"}, {"data": {"id": "run--a96cf5f7-6ca5-4ff5-a730-22766a4592f0-0", "name": null, "type": "ai", "content": "Chào bạn Tin,\\n\\nBạn muốn đăng ký tạm trú chi tiết, tôi sẽ cung cấp đầy đủ thông tin về thủ tục này dựa trên dữ liệu từ Cổng Dịch vụ công Bộ Công an.\\n\\n**Tên dịch vụ:** Đăng ký tạm trú\\n**Lĩnh vực:** Đăng ký, quản lý cư trú\\n**URL chi tiết:** [https://dichvucong.bocongan.gov.vn/bocongan/bothutuc/tthc?matt=26356](https://dichvucong.bocongan.gov.vn/bocongan/bothutuc/tthc?matt=26356)\\n\\n**1. Cơ quan thực hiện:**\\nCông an Xã\\n\\n**2. Cách thức thực hiện:**\\nBạn có thể lựa chọn một trong hai cách sau:\\n*   Trực tiếp\\n*   Trực tuyến\\n\\n**3. Trình tự thực hiện:**\\n\\n*   **Bước 1:** Cá nhân, tổ chức chuẩn bị hồ sơ theo quy định của pháp luật.\\n*   **Bước 2:** Cá nhân, tổ chức nộp hồ sơ tại Công an cấp xã.\\n*   **Bước 3:** Khi tiếp nhận hồ sơ đăng ký tạm trú, cơ quan đăng ký cư trú kiểm tra tính pháp lý và nội dung hồ sơ:\\n    *   Trường hợp hồ sơ đã đầy đủ, hợp lệ thì tiếp nhận hồ sơ và cấp Phiếu tiếp nhận hồ sơ và hẹn trả kết quả (mẫu CT04 ban hành kèm theo Thông tư số 56/2021/TT-BCA) cho người đăng ký.\\n    *   Trường hợp hồ sơ đủ điều kiện nhưng chưa đủ hồ sơ thì hướng dẫn bổ sung, hoàn thiện và cấp Phiếu hướng dẫn bổ sung, hoàn thiện hồ sơ (mẫu CT05 ban hành kèm theo Thông tư số 56/2021/TT-BCA) cho người đăng ký.\\n    *   Trường hợp hồ sơ không đủ điều kiện thì từ chối và cấp Phiếu từ chối tiếp nhận, giải quyết hồ sơ (mẫu CT06 ban hành kèm theo Thông tư số 56/2021/TT-BCA) cho người đăng ký.\\n*   **Bước 4:** Cá nhân, tổ chức nộp lệ phí đăng ký cư trú theo quy định.\\n*   **Bước 5:** Căn cứ theo ngày hẹn trên Phiếu tiếp nhận hồ sơ và hẹn trả kết quả để nhận thông báo kết quả giải quyết thủ tục đăng ký cư trú (nếu có).\\n\\n**4. Thời hạn giải quyết:**\\nThời hạn giải quyết là **03 Ngày làm việc** kể từ ngày nộp hồ sơ, áp dụng cho cả hình thức trực tiếp và trực tuyến.\\nThời gian tiếp nhận hồ sơ: Giờ hành chính các ngày làm việc từ thứ 2 đến thứ 6 và sáng thứ 7 hàng tuần (trừ các ngày nghỉ lễ, tết theo quy định của pháp luật).\\n\\n**5. Phí và Lệ phí:**\\n*   Phí: 1\\n*   Lệ phí: Không\\n\\n**6. Thành phần hồ sơ:**\\nTùy thuộc vào trường hợp đăng ký, hồ sơ sẽ khác nhau:\\n\\n*   **Hồ sơ đăng ký tạm trú thông thường:**\\n    *   Tờ khai thay đổi thông tin cư trú (Mẫu CT01 ban hành kèm theo Thông tư số 56/2021/TT-BCA); đối với người đăng ký tạm trú là người chưa thành niên thì trong tờ khai phải ghi rõ ý kiến đồng ý của cha, mẹ hoặc người giám hộ, trừ trường hợp đã có ý kiến đồng ý bằng văn bản. (Số lượng: 1 Bản chính)\\n    *   Giấy tờ, tài liệu chứng minh chỗ ở hợp pháp. (Số lượng: 1 Bản chính)\\n\\n*   **Đăng ký tạm trú tại nơi đơn vị đóng quân trong Công an nhân dân:**\\n    *   Tờ khai thay đổi thông tin cư trú (Mẫu CT01 ban hành kèm theo Thông tư số 56/2021/TT-BCA). (Số lượng: 1 Bản chính)\\n    *   Giấy giới thiệu của Thủ trưởng đơn vị quản lý trực tiếp ghi rõ nội dung để làm thủ tục đăng ký tạm trú và đơn vị có chỗ ở cho cán bộ chiến sĩ (ký tên, đóng dấu). (Số lượng: 1 Bản chính)\\n\\n*   **Đăng ký tạm trú theo danh sách:**\\n    *   Tờ khai thay đổi thông tin cư trú (của từng người) (Mẫu CT01 ban hành kèm theo Thông tư số 56/2021/TT-BCA). (Số lượng: 1 Bản chính)\\n    *   Văn bản đề nghị đăng ký tạm trú trong đó ghi rõ thông tin về chỗ ở hợp pháp kèm danh sách người tạm trú. Danh sách bao gồm những thông tin cơ bản của từng người: họ, chữ đệm và tên; ngày, tháng, năm sinh; giới tính; số định danh cá nhân và thời hạn tạm trú. (Số lượng: 1 Bản chính)\\n\\n**7. Biểu mẫu:**\\nBạn có thể tải về mẫu Tờ khai thay đổi thông tin cư trú (Mẫu CT01 ban hành kèm theo Thông tư số 56/2021/TT-BCA) tại các đường dẫn sau:\\n*   [https://dichvucong.bocongan.gov.vn/public_dir/tttl/01/giayto/2023_10/1698204115_CT01.doc](https://dichvucong.bocongan.gov.vn/public_dir/tttl/01/giayto/2023_10/1698204115_CT01.doc)\\n*   [https://dichvucong.bocongan.vn/public_dir/tttl/01/giayto/2022_01/1643318294_CT01_To_khai_thay_doi_thong_tin_cu_tru.doc](https://dichvucong.bocongan.gov.vn/public_dir/tttl/01/giayto/2022_01/1643318294_CT01_To_khai_thay_doi_thong_tin_cu_tru.doc)\\n\\n**8. Kết quả thực hiện:**\\nSau khi hoàn thành thủ tục, bạn sẽ nhận được một trong các kết quả sau:\\n*   Cập nhật thông tin trong Cơ sở dữ liệu quốc gia về dân cư.\\n*   Cập nhật thông tin trong Cơ sở dữ liệu về cư trú.\\n*   Thông báo về kết quả giải quyết, hủy bỏ đăng ký cư trú.\\n*   Phiếu từ chối tiếp nhận, giải quyết hồ sơ (nếu hồ sơ không đủ điều kiện).\\n\\nHy vọng những thông tin chi tiết này sẽ giúp bạn thực hiện thủ tục đăng ký tạm trú một cách thuận lợi. Nếu bạn có bất kỳ thắc mắc nào khác, đừng ngần ngại hỏi nhé!", "example": false, "tool_calls": [], "usage_metadata": {"input_tokens": 2923, "total_tokens": 4687, "output_tokens": 1764, "input_token_details": {"cache_read": 0}, "output_token_details": {"reasoning": 193}}, "additional_kwargs": {}, "response_metadata": {"model_name": "gemini-2.5-flash", "finish_reason": "STOP", "safety_ratings": [], "prompt_feedback": {"block_reason": 0, "safety_ratings": []}}, "invalid_tool_calls": []}, "type": "ai"}]	hehe	2025-09-25 19:36:05.318701+00	2025-09-26 09:53:06.953672+00	t
